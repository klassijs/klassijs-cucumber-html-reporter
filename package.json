{
  "name": "klassijs-cucumber-html-reporter",
  "version": "6.0.4",
  "description": "Generates Cucumber HTML reports in three different themes",
  "type": "module",
  "main": "index.js",
  "typings": "./index.d.ts",
  "exports": {
    ".": "./index.js"
  }
,
  "author": {
    "name": "Kushang Gajjar",
    "email": "g.kushang@gmail.com"
  },
  "contributors": [
    {
      "name": "larryG",
      "url": "https://github.com/larryg01",
      "email": "larryg@klassitech.co.uk"
    },
    {
      "name": "carlosbermejop",
      "url": "https://github.com/carlosbermejop"
    },
    {
      "name": "BatsFanatic",
      "url": "https://github.com/BatsFanatic"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klassijs/klassijs-cucumber-html-reporter.git"
  },
  "bugs": {
    "url": "https://github.com/klassijs/klassijs-cucumber-html-reporter/issues"
  },
  "keywords": [
    "cucumber",
    "html",
    "cucumber-html-reporter",
    "html report",
    "json to html"
  ],
  "scripts": {
    "pretest": "node --trace-deprecation node_modules/@cucumber/cucumber/bin/cucumber-js test/features/ -r test/features/step_definitions -f json:test/report/cucumber_report.json --no-strict || true",
    "clean": "rm -rf screenshots",
    "test": "node --trace-deprecation test/createHtmlReports.js",
    "changelog": "standard-version",
    "changelog:patch": "standard-version --release-as patch --skip.commit --skip.tag",
    "changelog:minor": "standard-version --release-as minor --skip.commit --skip.tag",
    "changelog:major": "standard-version --release-as major --skip.commit --skip.tag"
  },
  "license": "MIT",
  "homepage": "https://github.com/klassijs/klassijs-cucumber-html-reporter#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "find": "^0.3.0",
    "fs-extra": "^11.3.4",
    "js-base64": "^3.7.8",
    "jsonfile": "^6.2.0",
    "lodash": "^4.17.23",
    "node-emoji": "^2.2.0",
    "open": "^11.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "standard-version": "github:klassijs/standard-version",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@cucumber/cucumber": "^12.7.0",
    "chai": "^5.1.2"
  }
}